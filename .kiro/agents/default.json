{
  "name": "autonomous-dev",
  "description": "Autonomous development agent with TDD workflow enforcement hooks",
  "prompt": "file://../../CLAUDE.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "use_aws",
    "web_search",
    "web_fetch",
    "thinking"
  ],
  "allowedTools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "use_aws",
    "web_search",
    "web_fetch",
    "thinking"
  ],
  "resources": [
    "file://../../AGENTS.md",
    "skill://../../skills/*/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "hooks/block-push-to-main.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/block-commit-outside-worktree.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/check-design-canvas.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/check-unit-tests.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/warn-skip-verification.sh",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/check-rebase-before-push.sh",
        "timeout_ms": 10000
      },
      {
        "matcher": "fs_write",
        "command": "hooks/check-test-plan.sh",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "matcher": "execute_bash",
        "command": "hooks/post-git-action-clear.sh commit design-canvas",
        "timeout_ms": 5000
      },
      {
        "matcher": "execute_bash",
        "command": "hooks/post-git-push.sh",
        "timeout_ms": 30000
      },
      {
        "matcher": "fs_write",
        "command": "hooks/post-file-edit-reminder.sh",
        "timeout_ms": 5000
      }
    ],
    "stop": [
      {
        "command": "hooks/verify-completion.sh",
        "timeout_ms": 10000
      }
    ]
  }
}
