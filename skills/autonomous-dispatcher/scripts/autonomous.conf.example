#!/bin/bash
# autonomous.conf — Configuration for the Autonomous Dev Team pipeline.
# Copy this file to autonomous.conf and fill in your project values.
# Values can also be overridden via environment variables.
#
# === Migration: 2026-05-17 — AGENT_*_EXTRA_ARGS introduced (closes #140) ===
#
# Existing gemini and kiro deployments depended on lib-agent.sh hardcoded
# flags that this release demotes to conf-level passthrough. After
# updating the user-scope skill (`npx skills update autonomous-dispatcher
# -g -y`):
#
#   - gemini deployments MUST add:
#       AGENT_DEV_EXTRA_ARGS="--approval-mode yolo --output-format stream-json"
#       AGENT_REVIEW_EXTRA_ARGS="--approval-mode yolo --output-format stream-json"
#   - kiro deployments MUST add:
#       AGENT_DEV_EXTRA_ARGS="--trust-all-tools"
#     (review-side falls through to run_agent for kiro and reads
#     DEV_EXTRA_ARGS too, so the dev-side var alone suffices)
#
# Without these conf updates, the dispatcher will produce hallucinated
# success / silent tool denial — the exact failure mode that #134 / #136
# fixed at the wrapper level. The fix has not regressed; ownership of
# the flag list moved to operator conf. claude / codex / opencode were
# unaffected (no operator-tunable defaults to demote).
#
# See the per-CLI EXTRA_ARGS blocks below for canonical values and
# operator-tunable additions (--debug, alternate output formats, etc.).
#
# === Prompt size: no longer bounded by MAX_ARG_STRLEN (closes #144) ===
#
# As of 2026-05-21, the wrapper feeds the constructed prompt to the agent
# CLI via stdin (`printf '%s' "$PROMPT" | <cli> ...`) instead of a
# positional argv element. Pre-#144, an issue whose `gh issue view --json
# title,body,comments` output exceeded 128 KB (Linux MAX_ARG_STRLEN =
# 32 * PAGE_SIZE) crashed the wrapper at `setsid: Argument list too long`
# (exit 126) on every dispatcher tick — a size-based silent perma-stall.
# Operator action required: none. The change is internal; perma-stalled
# issues recover on their next dispatcher tick after the upgrade.
# Operators authoring custom AGENT_LAUNCHER values must ensure the
# launcher forwards stdin to the CLI exec — `exec $CLAUDE_CMD "$@"` does
# this implicitly; a wrapper that captures stdin (e.g. for
# instrumentation) and doesn't replay it would break the channel.
# See [INV-34] in docs/pipeline/invariants.md for the full contract.
#
# === Deployment topologies (post-#104; lib-resolution post-#227) ===
#
# Two supported layouts. Both work because every entry script computes its
# CONF dir from ${BASH_SOURCE[0]:-$0} per [INV-14], so the project-side symlink
# resolves to <project>/scripts/ where autonomous.conf lives.
#
# 1. Vendored per-project (the default after `npx skills add zxkane/...`):
#      <project>/.agents/skills/.../scripts/dispatch-local.sh   (real)
#      <project>/scripts/dispatch-local.sh -> ...               (symlink)
#    Upstream skill upgrade requires `npx skills update -p` per project.
#
# 2. Shared install (one install across many projects):
#      ~/.claude/skills/.../scripts/dispatch-local.sh           (real)
#      <project>/scripts/dispatch-local.sh -> ...               (symlink)
#    Upstream upgrade is a single `npx skills update -g` for all
#    projects symlinked into the shared install. Useful if you run
#    multiple project pipelines on the same host and want one upgrade
#    point. Set up by running `npx skills add zxkane/... -g` once at
#    user scope and creating per-project <project>/scripts/<file>.sh
#    symlinks pointing into the user-scope install.
#
#    SYMLINK MANIFEST (post-#227, [INV-65]): the project's <project>/scripts/
#    needs symlinks ONLY for the STABLE ENTRY scripts + agent-callable
#    utilities — i.e. EVERYTHING THAT IS NOT `lib-*.sh`, MINUS the two
#    `*-aws-ssm.sh` helpers. Entry scripts source their sibling lib-*.sh from
#    the REAL skill tree (resolved via `readlink -f` → LIB_DIR), so a NEW
#    upstream lib-*.sh needs NO new project symlink and CANNOT crash the wrapper
#    on a missing `source`. The entry set:
#
#      autonomous-dev.sh, autonomous-review.sh, dispatch-local.sh,
#      dispatcher-tick.sh, dispatcher-multi-tick.sh,
#      setup-labels.sh, post-verdict.sh,
#      gh-app-token.sh, gh-with-token-refresh.sh, gh-token-refresh-daemon.sh,
#      gh-as-user.sh, mark-issue-checkbox.sh, reply-to-comments.sh,
#      resolve-threads.sh, upload-screenshot.sh
#
#    `lib-*.sh` are intentionally NOT symlinked (resolved from the skill tree).
#    The two `*-aws-ssm.sh` helpers are ALSO NOT symlinked (#227 P1): they
#    source lib-ssm.sh from their own dir and are invoked by the dispatcher
#    from the skill tree (never via a project-side symlink), so a project-side
#    symlink to them would crash on the now-absent lib-ssm.sh.
#    Let `install-project-hooks.sh` manage this — it symlinks exactly this set,
#    prunes any stale per-lib / `*-aws-ssm.sh` symlinks a pre-#227 install left
#    behind, and offers `--doctor` (health report) and `--dry-run` (plan only).
#    Re-running it after an upstream upgrade is only needed when an ENTRY point
#    is added or removed — never for lib-*.sh changes.
#
#    Verify with: `<project>/scripts/install-project-hooks.sh --doctor` or
#    `ls -la <project>/scripts/`.
#
# Either way, this autonomous.conf lives at <project>/scripts/ and is
# discovered via the entry's CONF dir (tier-2 in lib-config.sh). Entries hand
# that CONF dir to the sourced libs via the exported AUTONOMOUS_CONF_DIR
# ([INV-65]) so conf lookup stays project-anchored even though the libs
# themselves are sourced from the skill tree.

# === Project Identity ===
PROJECT_ID="my-project"
REPO="owner/repo-name"
REPO_OWNER="owner"
REPO_NAME="repo-name"
PROJECT_DIR="/path/to/project"

# === Agent Configuration ===
# AGENT_CMD: which coding-agent CLI to spawn for dev/review wrappers.
# First-class support: claude, codex, gemini, kiro, opencode, agy. Other
# CLIs work via the generic `<cli> -p <prompt>` fallback. See README
# "Supported Agent CLIs" for resume semantics per CLI.
#
# opencode prerequisites (provider-agnostic CLI, no defaults):
#   1. Run `opencode providers login` once on this box to set up
#      credentials for at least one model provider.
#   2. Set AGENT_DEV_MODEL and AGENT_REVIEW_MODEL below to explicit
#      `provider/model` strings (e.g. "anthropic/claude-sonnet-4-6").
#      Leaving them empty leaves opencode without a model to call.
#
# gemini prerequisites:
#   1. CLI 0.42.0+ (need the documented stream-json schema).
#   2. AGENT_DEV_EXTRA_ARGS / AGENT_REVIEW_EXTRA_ARGS MUST be set to
#      `--approval-mode yolo --output-format stream-json` (closes #140).
#      Without --approval-mode yolo, every shell/write tool defaults to
#      ask_user→deny in headless mode (the silent fabrication failure
#      mode from #102). See the "gemini block" further below for
#      canonical values.
#   3. Valid AGENT_DEV_MODEL / AGENT_REVIEW_MODEL ids per
#      https://geminicli.com/docs/reference/configuration/:
#        gemini-3-pro-preview, gemini-3-flash-preview,
#        gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
#      `gemini-3-pro` (without -preview) is NOT a valid id.
#
# kiro prerequisites:
#   1. AGENT_DEV_EXTRA_ARGS MUST be set to `--trust-all-tools` on stock
#      kiro installs (closes #140; replaces the pre-#140
#      AGENT_PERMISSION_MODE=bypassPermissions wiring). Without the
#      flag, headless --no-interactive mode denies every coding tool
#      and kiro emits a fluent fabricated success at exit 0 (the #102
#      R5 failure mode, originally fixed in #136). Operators with a
#      customized ~/.kiro/agents/<name>.json that already permits
#      coding tools can leave EXTRA_ARGS empty. See the "kiro block"
#      further below for canonical values.
#   2. KIRO_AGENT_NAME — defaults to `autonomous-dev`. Override below
#      if your kiro install ships a different agent name (e.g. stock
#      installs use `default`).
AGENT_CMD="claude"
# AGENT_DEV_MODEL / AGENT_REVIEW_MODEL: model passed via the CLI's
# --model flag. Empty = let the CLI pick its default (claude / codex /
# gemini — opencode has no default and will fail if both are empty when
# AGENT_CMD=opencode).
AGENT_DEV_MODEL=""
AGENT_REVIEW_MODEL="sonnet"
# WARNING: 'bypassPermissions' grants the agent unrestricted shell access.
# Only use in trusted, sandboxed environments (containers, dedicated VMs).
# For production on shared hosts, use 'auto' or 'plan'.
AGENT_PERMISSION_MODE="auto"

# Wall-clock cap for each agent invocation (run_agent / resume_agent).
# Accepts coreutils `timeout` units: s, m, h, d. Default 4h.
# Prevents hung CLI processes (e.g. claude --resume against a completed
# session, MCP stdio deadlock) from monopolizing wrapper PID slots.
# Closes #60 (INV-13).
#
# This is the DEV-side cap; the review side has its own (smaller) default —
# see AGENT_REVIEW_TIMEOUT below.
AGENT_TIMEOUT="4h"

# AGENT_REVIEW_TIMEOUT: per-side wall-clock cap for REVIEW-agent CLIs only
# (INV-48, #185). The shared AGENT_TIMEOUT above is generous (4h) because a dev
# run can legitimately take hours; a code REVIEW is ~1-2 min, so a review CLI
# that runs for hours is almost always hung. Capping review at 1h by default
# reaps a silently-hung review CLI ~3h sooner (observed: a review CLI hung for
# ~3h, holding a wrapper PID slot until the 4h AGENT_TIMEOUT would have fired).
#
# Accepts the same coreutils `timeout` units as AGENT_TIMEOUT (s/m/h/d) or a
# bare integer (seconds). Default 1h. The DEV side is UNAFFECTED — it always
# uses AGENT_TIMEOUT. A review agent killed BY this cap (CLI exit 124/137) with
# no posted verdict VETOES the merge (deciding FAIL), it is NOT silently dropped
# from the multi-agent unanimous-PASS vote.
#
# Invalid (non-`timeout`-unit) or `0` values fail loud at review startup
# (`timeout 0` would DISABLE the cap). Leave unset for the 1h default.
# AGENT_REVIEW_TIMEOUT="1h"

# Optional launcher prefix wrapped around every claude CLI invocation
# in run_agent / resume_agent. Use case: bridge dispatcher-spawned
# wrappers into the same env you set up for interactive `claude` runs
# (Bedrock auth, MCP servers, telemetry tags, etc.) without duplicating
# that env in autonomous.conf.
#
# Contract: the launcher script is responsible for invoking the claude
# binary itself (typically ending with `exec claude "$@"` or a shell
# function that ends with `$CLAUDE_CMD "$@"`). The wrapper passes only
# claude flags + prompt as "$@" — NOT the binary name. Required for the
# claude branch only; mixing AGENT_LAUNCHER with AGENT_CMD≠claude is
# rejected at startup since the canonical launchers are claude-specific.
#
# The dev / review wrappers also export
#   CC_USER=autonomous-{dev,review}-bot
#   CC_ROLE_KIND={dev,review}
# before invoking the launcher, so a launcher that consumes these (e.g.
# the cc shell function piping CC_USER through to AWS STS session tags
# via cc-creds) can attribute autonomous-pipeline traffic separately
# from interactive sessions in cost / telemetry pipelines.
#
# Example — a `cc` shell function defined in ~/.bash_aliases that
# injects Bedrock + telemetry env and then invokes claude:
#
#   AGENT_LAUNCHER='bash -c '\''source ~/.bash_aliases && cc "$@"'\'' --'
#
# Notes:
#   * Use `cc "$@"` — NOT `exec cc "$@"`. `exec` only runs external
#     binaries, so on most Linux distros it resolves `cc` to
#     /usr/bin/cc (the GNU C compiler) and the dispatch crashes with
#     `unrecognized command-line option '--model'`.
#   * `cc` must be defined as a shell *function* (not an alias). bash
#     non-interactive shells do not expand aliases by default, so a cc
#     alias would be ignored and PATH lookup would again find the
#     C compiler.
#   * The launcher is sourced once by lib-agent.sh and tokenized via
#     `eval`. Treat its contents as code, not data.
#
# Default: leave AGENT_LAUNCHER unset (commented out). Most operators
# use the wrapper's direct claude invocation.
#
# AGENT_LAUNCHER=''

# === Per-CLI extra arguments (closes #140) ===
#
# AGENT_DEV_EXTRA_ARGS / AGENT_REVIEW_EXTRA_ARGS are flat strings whose
# tokens are appended verbatim after the structural arguments of every
# `run_agent` (dev) / `resume_agent` (review) call and before the prompt
# positional. Defaults are empty. Tokenization uses `eval` (same trust
# model as AGENT_LAUNCHER), so quoted values containing spaces survive
# intact:
#   AGENT_DEV_EXTRA_ARGS='--policy "/path with spaces/policy.json"'
#
# The five per-CLI blocks below show canonical values. UNCOMMENT only
# the block matching your AGENT_CMD setting.
AGENT_DEV_EXTRA_ARGS=""
AGENT_REVIEW_EXTRA_ARGS=""

# AGENT_DEV_LAUNCHER / AGENT_REVIEW_LAUNCHER: per-side override of
# AGENT_LAUNCHER (INV-38). Default to AGENT_LAUNCHER when unset/empty
# so existing single-launcher deployments are unaffected. Set them
# when dev and review run on different CLIs and need different
# launcher treatment — for example, claude for dev with a Bedrock-
# bridge launcher (cc), kiro for review with no launcher:
#
#   AGENT_CMD="claude"
#   AGENT_DEV_LAUNCHER='bash -c '\''source ~/.bash_aliases && cc "$@"'\'' --'
#   AGENT_REVIEW_CMD="kiro"
#
# Per-side guard (INV-38): each side's launcher is gated against
# THAT side's AGENT_CMD. AGENT_DEV_LAUNCHER non-empty requires
# AGENT_DEV_CMD=claude; AGENT_REVIEW_LAUNCHER non-empty requires
# AGENT_REVIEW_CMD=claude. Side that has no launcher is unconstrained.
#
# Caveat for kiro-on-review with --trust-all-tools: the EXTRA_ARGS
# vars are mapped by execution stage (run_agent / resume_agent), not
# by side, so `AGENT_DEV_EXTRA_ARGS="--trust-all-tools"` would be
# picked up by the claude DEV invocation (which doesn't accept that
# flag) AS WELL AS the kiro REVIEW invocation. Operators needing
# kiro-side --trust-all-tools today should configure it via a
# customized ~/.kiro/agents/<name>.json (see "kiro block" below for
# the canonical knob) rather than via AGENT_DEV_EXTRA_ARGS, until the
# stage-vs-side EXTRA_ARGS gap is closed in a follow-up.
# AGENT_DEV_LAUNCHER=""
# AGENT_REVIEW_LAUNCHER=""

# AGENT_DEV_CMD / AGENT_REVIEW_CMD: per-side override of AGENT_CMD.
# Default to AGENT_CMD when unset/empty, so existing single-CLI
# deployments are unaffected. Set them when you want dev and review
# to run on different CLIs — for example, claude for the heavy dev
# work and agy for the cheaper review pass:
#
#   AGENT_CMD="claude"           # also used by anything not split
#   AGENT_REVIEW_CMD="agy"       # only review goes to agy
#   AGENT_DEV_MODEL="opus[1m]"
#   AGENT_REVIEW_MODEL="Gemini 3.5 Flash (High)"  # an agy-namespace model — see agy block
#
# AGENT_LAUNCHER (claude-only) is gated per-side by INV-38: each side's
# launcher requires THAT side's CLI to be claude. The natural mixed-
# CLI deployment (claude dev with cc + non-claude review without
# launcher) works — see AGENT_DEV_LAUNCHER block above.
# AGENT_DEV_CMD=""
# AGENT_REVIEW_CMD=""

# AGENT_REVIEW_AGENTS: space-separated list of verdict-reaching review CLIs
# to run IN PARALLEL against the same PR, gating the merge on their UNANIMOUS
# agreement (INV-40, #166). Empty/unset (the default) = single-agent review
# using AGENT_REVIEW_CMD — byte-for-byte the legacy behavior.
#
#   AGENT_REVIEW_AGENTS="agy kiro"   # both must PASS for auto-merge
#
# How it works: the review wrapper spawns one parallel subshell per listed
# agent, each with its own session id, its own log, and (INV-38) the launcher
# neutralized for non-claude members. Each agent reaches an independent
# approve/pushback verdict and ends its comment with a `Review Agent: <name>`
# discriminator; the wrapper attributes each verdict per agent and aggregates:
#   - PASS iff every AVAILABLE agent passed; any single FAIL → aggregated FAIL
#     (→ −reviewing +pending-dev);
#   - an agent is "unavailable" (dropped, with a WARN) if its CLI fails to
#     launch OR posts no verdict within the poll window; a FAIL it did post
#     still counts;
#   - if ALL agents are unavailable → today's single-agent crash fallback.
#
# DISTINCT from REVIEW_BOTS (below): REVIEW_BOTS triggers external GitHub bots
# whose comments are read as INPUT by the verdict agent(s); AGENT_REVIEW_AGENTS
# runs N independent verdict-reaching agents.
#
# The fan-out is internal to the wrapper: the dispatcher, the review-N.pid
# file, and the `reviewing` label are unchanged. The dispatcher Step 5b
# liveness model still sees one review wrapper per issue.
# AGENT_REVIEW_AGENTS=""

# Per-agent model / extra-args overrides (INV-41, #168) -----------------------
# By default every agent in AGENT_REVIEW_AGENTS shares AGENT_REVIEW_MODEL and
# AGENT_REVIEW_EXTRA_ARGS. To give a specific agent its OWN model or flags, set
# a per-agent key: the agent name uppercased with every non-alphanumeric char
# mapped to `_` (agy → AGY, kiro → KIRO, claude-code → CLAUDE_CODE):
#
#   AGENT_REVIEW_MODEL_<AGENT>="..."        # per-agent model
#   AGENT_REVIEW_EXTRA_ARGS_<AGENT>="..."   # per-agent extra CLI args
#
# Precedence: per-agent key (if set AND non-empty) → shared AGENT_REVIEW_MODEL /
# AGENT_REVIEW_EXTRA_ARGS → lib default (sonnet for model, empty for args). An
# all-unset config is byte-for-byte the shared-value behavior.
#
# Worked example — a mixed "kiro <claude-fam>" fleet where the two CLIs use
# INCOMPATIBLE model namespaces (kiro rejects `sonnet[1m]`; claude rejects
# `claude-sonnet-4.6`):
#
#   AGENT_REVIEW_AGENTS="kiro agy"
#   AGENT_REVIEW_MODEL="claude-sonnet-4.6"            # kiro-namespace shared default
#   AGENT_REVIEW_MODEL_AGY="Gemini 3.5 Flash (High)"  # agy gets a real agy-namespace model
#   AGENT_REVIEW_EXTRA_ARGS_KIRO="--trust-all-tools"  # kiro-only flag
#   # kiro has no per-agent model key → uses the shared "claude-sonnet-4.6".
#   # agy DOES consume --model now but validates against `agy models` (INV-50):
#   # giving it the shared kiro id would make agy WARN and run its default, so
#   # set AGENT_REVIEW_MODEL_AGY to a valid agy-namespace name. agy still uses
#   # the shared AGENT_REVIEW_EXTRA_ARGS.
#
# Note: the review fan-out runs a FRESH run_agent (not resume_agent), so on the
# review side the resolved extra-args is threaded through AGENT_DEV_EXTRA_ARGS
# internally (the var run_agent's _parse_extra_args reads). You configure only
# the review knobs above; the wrapper handles the plumbing per-subshell.
#
# Diagnostics (INV-58, #205): when an `agy` fan-out member is dropped
# `unavailable` because it hit the Antigravity quota wall (HTTP 429
# RESOURCE_EXHAUSTED, "Individual quota reached") or an auth failure, agy exits
# rc 0 with no verdict. The wrapper now scrapes agy's own --log-file and surfaces
# a distinct reason — `quota-exhausted (… resets in <dur>)` or `auth-failed` — in
# the "dropped (unavailable) agent(s)" log line + issue comment, so you can tell
# agy ran out of quota (and roughly when it recovers) without digging into agy's
# separate log. This is observability only: a quota-walled agy is still dropped
# from the unanimous-PASS vote, NOT a deciding FAIL, so the fleet degrades to the
# surviving members rather than blocking every merge until agy's quota resets.
# The `Fanning out …` log line and the Reviewed-HEAD trailer also report each
# agent's PER-AGENT resolved model (e.g. the AGENT_REVIEW_MODEL_AGY above), not
# the shared AGENT_REVIEW_MODEL default.

# Per-agent launcher overrides (INV-42, #173) --------------------------------
# Same per-agent suffix convention as the model/extra-args keys above, but for
# the LAUNCHER. Use this when one fan-out member is a non-claude CLI that needs
# its own launcher wrapper to run headless from the dispatcher's nohup shell —
# e.g. `codex` (like `cc` for claude) is a ~/.bash_aliases function that starts
# a per-machine bedrock proxy and exports OPENAI_BASE_URL + a dummy
# OPENAI_API_KEY before exec'ing the real CLI:
#
#   AGENT_REVIEW_LAUNCHER_<AGENT>="..."   # per-agent launcher argv (eval-tokenized)
#
# Precedence (mirrors AGENT_REVIEW_MODEL_<AGENT> EXCEPT for the fallback):
#   - per-agent key set AND non-empty → applied as THIS agent's launcher;
#   - else → the agent keeps the current INV-38 behavior (non-claude member's
#     launcher zeroed; a claude member keeps the shared AGENT_REVIEW_LAUNCHER).
# There is DELIBERATELY no fallback to the shared AGENT_REVIEW_LAUNCHER: that
# shared launcher is claude-only (INV-38) and must not auto-apply to a
# non-claude per-agent slot. Setting AGENT_REVIEW_LAUNCHER_<AGENT> is you
# asserting "this launcher fits THIS CLI", so it bypasses the INV-38 claude-only
# guard for that agent specifically (the SHARED AGENT_REVIEW_LAUNCHER keeps its
# claude-only restriction). A tokenize failure logs an ERROR and runs naked.
#
# Worked example — a three-agent fleet adding codex via the bash-aliases bridge,
# the SAME `bash -c 'source ~/.bash_aliases && <fn> "$@"' --` shape used for the
# `cc` claude launcher in AGENT_DEV_LAUNCHER above:
#
#   AGENT_REVIEW_AGENTS="kiro agy codex"
#   AGENT_REVIEW_MODEL_CODEX="gpt-5.5"          # codex's own model id (INV-41)
#   AGENT_REVIEW_LAUNCHER_CODEX=$'bash -c \'source ~/.bash_aliases && codex "$@"\' --'
#   # kiro / agy have no per-agent launcher key → kiro and agy run with the
#   # launcher zeroed (INV-38), exactly as before.
#
# Scope is per-subshell — the per-agent launcher never leaks to the dev side or
# to a sibling fan-out member.

# CODEX_REVIEW_MAX_RERUNS: codex review re-run bound (INV-62, #218). When a
# fan-out review agent is codex, the wrapper runs the purpose-built
# `codex review "<prompt>"` subcommand — natively multi-step, auto-scopes the diff
# to the PR's merge target, so it never strands mid-review on a large diff (this
# replaced the pre-#218 `codex exec` + auto-resume loop + inline-diff machinery).
# `codex review` has no resume; a transient non-zero exit (an upstream stream
# blip / `turn.failed` — #209) is ridden out by RE-RUNNING a fresh review, up to
# this many re-runs AND within the AGENT_REVIEW_TIMEOUT wall-clock cap. On
# exhaustion codex falls back to today's `unavailable` behavior (no regression).
# Default 3. Set to 0 to DISABLE re-runs (a single `codex review` invocation).
# Only affects the codex review path; claude/agy/kiro/gemini are untouched.
#
# CODEX_REVIEW_MAX_RERUNS=3

# Pre-fan-out agent-smoke gate (INV-64, #224) ------------------------------
# REVIEW_SMOKE_ENABLED: when "true", the review wrapper runs a cheap one-token
# smoke against EVERY AGENT_REVIEW_AGENTS member BEFORE the review fan-out
# (Phase A.5 — after the INV-46 E2E lane, before the fan-out loop). It uses the
# SAME launch path the fan-out will (the INV-41 per-agent model + INV-38/INV-42
# launcher) via lib-agent-smoke.sh::smoke_agent (INV-63, #222), and applies
# three-state semantics:
#   - PASS        → the member proceeds to the fan-out;
#   - UNAVAILABLE → the member is dropped from the vote (quota/capacity — the same
#                   INV-40 `unavailable` tolerance; drop reason `smoke: <reason>`);
#                   the remaining members vote normally, and ALL-unavailable falls
#                   to the existing all-unavailable terminal path;
#   - FAIL        → the WHOLE review is ABORTED loudly: no fan-out, no verdict, the
#                   issue stays `reviewing`, and a comment names the failed agent(s)
#                   + the SMOKE evidence. A smoke FAIL is operator-side config
#                   breakage (wrong model id / expired auth / region drift / a
#                   launcher that does not fit the CLI), NOT a PR defect — bouncing
#                   to dev would chase a non-existent PR problem, so it stays
#                   `reviewing` and self-heals on the next tick once you fix the
#                   config.
# Why a misconfigured member matters: without the smoke it burns a full review run
# (E2E + N review agents + the poll window) before surfacing as an opaque
# `unavailable`, indistinguishable from a quota wall. The smoke separates the two
# cheaply, up front.
#
# Default OFF — opt in per project (rollout is per-project and individually
# revertible). With it off, the wrapper behavior is byte-for-byte unchanged.
# Single-agent projects benefit too: a smoke FAIL aborts (stays `reviewing`); a
# smoke UNAVAILABLE falls to the all-unavailable path (same terminal state as a
# review crash).
#
# REVIEW_SMOKE_ENABLED="false"
#
# REVIEW_SMOKE_TIMEOUT_SECONDS: per-member smoke wall-clock cap. A smoke is a
# one-token round-trip; 120s is generous headroom for cold-start auth + first
# token on a slow backend. Accepts the same coreutils `timeout` units as
# AGENT_TIMEOUT (s/m/h/d) or bare seconds. Rejected at startup: 0 (GNU
# `timeout 0` DISABLES the cap), fractions, negatives, other units.
#
# REVIEW_SMOKE_TIMEOUT_SECONDS="120"

# --- claude block ---
# claude has NO required EXTRA_ARGS — the structural --permission-mode
# flag handles tool trust via the existing AGENT_PERMISSION_MODE knob.
# Common operator additions: --debug for verbose logging, alternate
# --output-format if your downstream parser expects a different shape.
#
# AGENT_CMD="claude"
# AGENT_DEV_EXTRA_ARGS=""
# AGENT_REVIEW_EXTRA_ARGS=""
# Example with debug logging:
# AGENT_DEV_EXTRA_ARGS="--debug"

# --- gemini block ---
# Both flags are LOAD-BEARING (closes #134). Without --approval-mode
# yolo, every write/shell tool defaults to ask_user→deny in headless
# mode and gemini emits a fluent fabricated success at exit 0 — the
# #102 R2 silent fabrication failure mode. --output-format stream-json
# (vs the bare `json` end-of-run blob) is required for the wrapper's
# heartbeat liveness signals to fire.
#
# AGENT_CMD="gemini"
# AGENT_DEV_MODEL="gemini-2.5-pro"          # or gemini-3-pro-preview
# AGENT_REVIEW_MODEL="gemini-2.5-pro"
# AGENT_DEV_EXTRA_ARGS="--approval-mode yolo --output-format stream-json"
# AGENT_REVIEW_EXTRA_ARGS="--approval-mode yolo --output-format stream-json"

# --- kiro block ---
# --trust-all-tools is LOAD-BEARING on stock kiro installs (closes #136):
# the default kiro agent's allowedTools denies every coding tool in
# --no-interactive mode and emits a fluent fabricated success at exit 0
# — the #102 R5 silent fabrication failure mode. Operators with a
# customized ~/.kiro/agents/<name>.json that already permits coding
# tools can leave this empty.
#
# Note: kiro's resume_agent falls through to run_agent (no session model)
# and reads AGENT_DEV_EXTRA_ARGS, so setting AGENT_REVIEW_EXTRA_ARGS is
# generally unnecessary for kiro.
#
# AGENT_CMD="kiro"
# AGENT_DEV_MODEL="claude-opus-4.7"
# AGENT_REVIEW_MODEL="claude-sonnet-4.6"
# AGENT_DEV_EXTRA_ARGS="--trust-all-tools"

# --- codex block ---
# codex has NO required EXTRA_ARGS — `exec --json` is structural and
# codex's tool execution doesn't have an analogue to gemini's
# ask_user→deny default. The model ID set below is valid for
# ChatGPT-account auth; API-key auth has a different valid set.
#
# AGENT_CMD="codex"
# AGENT_DEV_MODEL="gpt-5.4"
# AGENT_REVIEW_MODEL="gpt-5.4"
# AGENT_DEV_EXTRA_ARGS=""
# AGENT_REVIEW_EXTRA_ARGS=""

# --- opencode block ---
# opencode has NO required EXTRA_ARGS — `run --format json` is
# structural and the provider/model selector below is forwarded via
# the standard --model flag. opencode is provider-agnostic; the model
# id MUST be in `provider/model` form (e.g.
# `amazon-bedrock/global.anthropic.claude-opus-4-7`).
#
# AGENT_CMD="opencode"
# AGENT_DEV_MODEL="amazon-bedrock/global.anthropic.claude-opus-4-7"
# AGENT_REVIEW_MODEL="anthropic/claude-sonnet-4-6"
# AGENT_DEV_EXTRA_ARGS=""
# AGENT_REVIEW_EXTRA_ARGS=""

# --- agy block ---
# Antigravity 2.0 CLI (Google) — successor to gemini CLI.
#
# Structural flags managed by lib-agent.sh (NOT to add here):
#   -p, --dangerously-skip-permissions, --print-timeout, --log-file
#
# Operator notes:
#   1. agy accepts --model. The value MUST be a name from `agy models`
#      (spaces/parens included — quote them); the wrapper validates the
#      resolved AGENT_DEV_MODEL / AGENT_REVIEW_MODEL against that list and
#      OMITS --model with a WARN if the value is not a known agy model.
#      (agy would otherwise silently run its DEFAULT model — it returns
#      rc 0 for any --model string and does NOT reject invalid ids, so the
#      wrapper is the gate. See [INV-50] and docs/pipeline/agy-cli-support.md.)
#      AGENT_DEV_MODEL / AGENT_REVIEW_MODEL are honored when they name a
#      real agy model.
#   2. --dangerously-skip-permissions is structural and load-bearing
#      for headless tool execution; without it agy denies every tool
#      call (silent fabrication failure, same shape as gemini's
#      ask_user→deny default that --approval-mode yolo fixes).
#   3. agy's internal --print-timeout default is 5 minutes. lib-agent
#      passes AGENT_TIMEOUT through so the outer wall-clock cap is
#      authoritative.
#   4. Conversation IDs are minted by agy and captured from the CLI
#      log file via grep — see [INV-36] in docs/pipeline/invariants.md
#      for the best-effort contract.
#
# AGENT_CMD="agy"
# AGENT_DEV_MODEL="Gemini 3.5 Flash (High)"     # must be a name from `agy models`
# AGENT_REVIEW_MODEL="Gemini 3.5 Flash (High)"  # must be a name from `agy models`
# AGENT_DEV_EXTRA_ARGS=""
# AGENT_REVIEW_EXTRA_ARGS=""

# === GitHub Authentication ===
GH_AUTH_MODE="token"
DEV_AGENT_APP_ID=""
DEV_AGENT_APP_PEM=""
REVIEW_AGENT_APP_ID=""
REVIEW_AGENT_APP_PEM=""
DISPATCHER_APP_ID=""
DISPATCHER_APP_PEM=""

# Absolute path to the real `gh` CLI binary. Set this when `gh` is installed
# outside the minimal POSIX PATH (Homebrew, nvm, asdf, ~/bin, /snap/bin,
# container /opt/gh, etc.) AND the dispatcher/wrappers may be spawned from
# a non-interactive shell that didn't source rc files (cron, systemd,
# AWS SSM, GitHub Actions, nohup). Closes #92.
# Example:
#   REAL_GH="/home/ubuntu/.linuxbrew/homebrew/bin/gh"
REAL_GH=""

# === Concurrency ===
MAX_CONCURRENT=5
MAX_RETRIES=3

# Cold-start grace window for stale detection ([INV-18], #99 Bug 1).
# After a Step 2/3/4 dispatch, the wrapper needs time to spawn the session,
# have the agent CLI make its first API call, and write its PID file. Step 5
# must NOT classify the wrapper as crashed during this window.
#
# Empirical measurements on a real dev box: wrapper startup → first agent
# activity is consistently 1–7 seconds across 10 sampled runs. 600 (10 min)
# leaves 90× headroom for slow MCP negotiation, model first-call slowness,
# or remote SSM dispatch latency, while still catching genuinely-dead
# wrappers within two ticks. Set to 0 to disable (not recommended — false-
# positive crash detection is the failure mode this knob exists to prevent).
DISPATCH_GRACE_PERIOD_SECONDS=600

# Wrapper heartbeat interval ([INV-24], #111 Part B).
# autonomous-dev.sh / autonomous-review.sh spawn a background loop that
# touches their PID file every HEARTBEAT_INTERVAL_SECONDS while they're
# running. The dispatcher's pid_alive check then honors a mtime-based
# fallback: a stale `kill -0` is upgraded to ALIVE if the PID-file mtime
# is within HEARTBEAT_INTERVAL_SECONDS * 3 (default 360s).
#
# Why: long-running review wrappers (15-30 min E2E + multi-bot rounds)
# routinely race with the dispatcher's pid_alive probe. A positive
# heartbeat signal lets the dispatcher distinguish "wrapper still
# working" from "wrapper truly hung". Set to 0 to disable both the
# wrapper-side spawn and the dispatcher-side mtime fallback.
HEARTBEAT_INTERVAL_SECONDS=120

# Metrics retention window ([INV-70], #228).
# The observe-only metrics lane (lib-metrics.sh) appends one JSON event per
# wrapper run / dispatcher decision to <state-dir>/metrics.jsonl. The aggregator
# `metrics-report.sh --prune-days N` drops lines older than N days (atomic
# rewrite); default 90. This var is the default N when --prune-days is omitted
# and a prune is requested. Emission itself is observe-only: a metrics failure
# NEVER affects wrapper/dispatcher behavior (INV-70), so leaving this default is
# always safe. See docs/pipeline/metrics.md.
METRICS_RETENTION_DAYS=90

# Review near-success window ([INV-24], #111 Part A).
# In Step 5b's review-DEAD branch, before declaring "crashed" the
# dispatcher cross-checks four PR-state signals — recent merge, recent
# APPROVED review, recent "Review PASSED|findings" comment, defensive
# kill -0 retry. If any is positive within this window, the crash path
# is skipped; the wrapper is either finishing or in its post-verdict
# tail. Set to 0 to restore legacy strict behavior (every pid_alive
# miss declares crashed).
#
# [INV-43, #172] If you run E2E_MODE=command with multi-agent review
# (AGENT_REVIEW_AGENTS), raise this to >= E2E_COMMAND_TIMEOUT_SECONDS
# (plus a tick of headroom) so a still-working command-mode review wrapper
# is not declared crashed and SIGTERMed mid-E2E.
REVIEW_NEAR_SUCCESS_WINDOW_SECONDS=300

# === Dev Agent ===
DEV_SKILL_CMD="/autonomous-dev"

# === Review Bots ===
# Space-separated short names of bot reviewers that MUST run on every PR
# before the autonomous-review wrapper approves. Configured bots are
# mandatory: the review prompt triggers each, polls for the bot's review
# (every 30s, timeout 3 min), and fails the review if any configured bot
# doesn't respond in time.
#
# Default: "" (disabled). Bot reviews are opt-in because each external
# bot is an availability dependency the operator takes on — when the bot
# is slow or unreachable, the review fails for a non-substantive reason
# and the issue bounces between pending-review and pending-dev (#149).
# Enable only when you actively want a specific bot's findings on every PR.
#
# Built-in registry:
#   q      → trigger "/q review",     login "amazon-q-developer[bot]"
#   codex  → trigger "/codex review", login "codex[bot]"
#   claude → trigger "@claude review", login "claude[bot]"
#
# Empty string disables bot-review enforcement entirely (the wrapper omits
# the bot-review section from the agent prompt).
#
# Custom bots: add the short name to REVIEW_BOTS, then declare
#   REVIEW_BOTS_<UPPERCASE_NAME>_TRIGGER="/your trigger"
#   REVIEW_BOTS_<UPPERCASE_NAME>_LOGIN="your-bot[bot]"
# Both must be set or the dispatcher tick fails fast at config validation.
#
# All three built-in bots reject GitHub App bot triggers, so the wrapper
# uses scripts/gh-as-user.sh to post as a real user.
REVIEW_BOTS=""

# === E2E Verification (optional) ===
#
# E2E has three modes (issue #161). The mode is selected by E2E_MODE.
# E2E_ENABLED is the legacy back-compat toggle but the wrapper internally
# drives off E2E_MODE.
#
#   E2E_MODE=none     — no E2E section in the review prompt (default
#                       when unset; equivalent to E2E_ENABLED=false).
#   E2E_MODE=browser  — Chrome DevTools MCP UI smoke test. For SaaS web
#                       apps with a per-PR preview URL. Requires
#                       E2E_PREVIEW_URL_PATTERN, E2E_TEST_USER_EMAIL,
#                       E2E_TEST_USER_PASSWORD. See
#                       skills/autonomous-review/references/e2e-verification.md
#   E2E_MODE=command  — invoke a project-supplied verify command. For
#                       backend pipelines, CLI tools, libraries,
#                       infra-as-code, or ML pipelines. Requires
#                       E2E_COMMAND, E2E_COMMAND_EVIDENCE_PARSER. See
#                       skills/autonomous-review/references/e2e-command-mode.md
#
# E2E_ENABLED=true with E2E_MODE unset is a fail-loud condition — the
# wrapper exits at startup. Projects must opt into a specific mode
# rather than implicitly inheriting "browser".
E2E_ENABLED="false"
E2E_MODE=""

# --- Browser mode fields (used when E2E_MODE=browser) -----------------------
E2E_PREVIEW_URL_PATTERN=""
E2E_TEST_USER_EMAIL=""
E2E_TEST_USER_PASSWORD=""
E2E_SCREENSHOT_UPLOAD="false"

# E2E_BROWSER_TIMEOUT_SECONDS: wall-clock cap for the browser-mode E2E lane
# (INV-48, #185). The browser E2E lane is an LLM run_agent lane (INV-46 Phase A),
# so it would otherwise inherit the aggressive 1h review cap (AGENT_REVIEW_TIMEOUT)
# and a slow preview deploy / cold start could be killed at 1h. This gives the
# browser lane its OWN cap, defaulting to the ORIGINAL AGENT_TIMEOUT (4h) so the
# review-cap shrink does NOT shrink browser E2E. Symmetric with command mode's
# E2E_COMMAND_TIMEOUT_SECONDS. Accepts `timeout` units (s/m/h/d) or bare seconds;
# `0` / invalid values fail loud at startup. Leave unset for the 4h default.
# E2E_BROWSER_TIMEOUT_SECONDS="4h"

# --- Command mode fields (used when E2E_MODE=command) -----------------------
#
# E2E_COMMAND: the verify command. The literal `${PR_NUMBER}` placeholder
# is substituted by the wrapper at render time. ALWAYS single-quote the
# value so your shell does not eagerly expand the placeholder when
# sourcing this file.
#
# Example for a backend-pipeline project:
#   E2E_COMMAND='bash scripts/e2e-pr-stage.sh ${PR_NUMBER}'
E2E_COMMAND=""

# E2E_COMMAND_PRE_HOOKS: optional. Runs before E2E_COMMAND. Failure aborts
# E2E. Same `${PR_NUMBER}` substitution. Example:
#   E2E_COMMAND_PRE_HOOKS='bash scripts/e2e-seed-pr-stage.sh ${PR_NUMBER}'
E2E_COMMAND_PRE_HOOKS=""

# E2E_COMMAND_TIMEOUT_SECONDS: hard cap, enforced via timeout(1).
# Default 3600 (60 min). MVP runs synchronously — values >3600 may
# exceed the agent's stalled-detection threshold. For longer pipelines
# wait for the background-mode follow-up.
#
# [INV-43, #172] Multi-agent review + command mode: the review wrapper's
# verdict-poll budget AUTO-SCALES from this value (no extra tuning needed),
# but you MUST also set REVIEW_NEAR_SUCCESS_WINDOW_SECONDS (above) to be
# >= E2E_COMMAND_TIMEOUT_SECONDS so the dispatcher does not declare a
# still-working command-mode review wrapper "crashed" and SIGTERM it
# mid-E2E. Otherwise a review agent that faithfully runs the slow E2E is
# dropped as `unavailable` from the unanimous-PASS vote. See
# skills/autonomous-review/references/e2e-command-mode.md ("Interaction with
# the multi-agent review wait/stall windows").
E2E_COMMAND_TIMEOUT_SECONDS=3600

# E2E_COMMAND_EVIDENCE_PARSER: REQUIRED when E2E_MODE=command. Reads the
# verify command's log file as $1, emits a markdown evidence block to
# stdout. The block MUST end with a SHA-bound marker:
#   <!-- e2e-evidence: complete sha="${PR_HEAD_SHA}" -->
# The wrapper exports PR_HEAD_SHA into the parser's environment;
# embedding it in the marker is load-bearing for idempotency (prevents
# a stale evidence comment from a prior commit silently satisfying a
# re-review of newer code). The review agent (not the wrapper) checks
# for the SHA-matching marker before posting and before reusing prior
# evidence, per the command-mode prompt block in autonomous-review.sh.
# See references/e2e-command-mode.md for the full contract.
E2E_COMMAND_EVIDENCE_PARSER=""
