# tests/unit/fixtures/provider-degraded/itp-degraded.caps
#
# NAMED degraded fake ITP provider manifest (#280, provider-spec.md §8
# fake-provider; design-spec §7.4 third bullet).
# Every gated ITP capability is set to its ABSENT value so EACH caps=0 / non-html
# branch is exercisable NOW — even though the caller branches that consume them
# ship in the downstream itp-reads / itp-writes issues. This is the test harness
# every later caps-branch issue builds on.

server_side_state_and=0      # list-all + client-side AND filter path
server_side_state_negation=0 # client-side negation filter
distinct_bot_author=0        # use the normalized authorKind field, not author==BOT
read_after_write_state=0     # re-read the task directly, not via search
cross_ref_shorthand=0        # dep refs carry full id / permalink
body_checkbox=0              # itp_mark_checkbox maps to subtask-complete
edit_comment=0               # INV-46 stamp falls back to re-posting the full report body + marker (never marker-only)
label_colors=0               # itp_provision_states skips color
marker_channel=text          # plain text channel (HTML comments stripped — Asana-like)
assignees=0                  # itp_list_by_state/itp_list_forbidden_combos normalize NO assignees field (#435)
